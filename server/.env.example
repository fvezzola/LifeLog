# LifeLog server config — copy to .env and fill in.

# Postgres connection. The docker-compose sets up a `postgres` service on
# port 5432 with these credentials by default; change them if you change
# docker-compose.yml.
DATABASE_URL=postgres://lifelog:lifelog@localhost:5432/lifelog

# JWT signing secret. MUST be a long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-32-bytes-of-random-hex

# Server bind address. Keep on localhost; Tailscale Serve fronts it with TLS.
PORT=3000
HOST=127.0.0.1

# Front-end origin allowed by CORS. For local dev with the PWA served from
# GitHub Pages, this is your Pages URL. For Tailscale-only access, this is
# your tailnet hostname.
ALLOWED_ORIGIN=https://fvezzola.github.io

# Public base URL of THIS server, used to build magic-link URLs. With
# Tailscale Serve this is your tailnet HTTPS hostname.
# Example: https://lifelog.tail-scales.ts.net
PUBLIC_URL=https://lifelog.example.ts.net

# Email delivery. Leave RESEND_API_KEY empty to print magic links to the
# server console (fine for single-user). Set it to enable email delivery.
# Get a key at https://resend.com (100 emails/day free).
RESEND_API_KEY=
RESEND_FROM=LifeLog <login@example.com>

# LifeLog server config — copy to .env and fill in.

# Postgres connection. Docker-compose sets up a `postgres` service on
# port 5432 with these credentials by default.
DATABASE_URL=postgres://lifelog:lifelog@localhost:5432/lifelog

# JWT signing secret. MUST be a long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-32-bytes-of-random-hex

# Server bind address. Keep on localhost; Tailscale Serve fronts it with TLS.
PORT=3000
HOST=127.0.0.1

# Where the PWA's static files live, relative to where you run the server
# (which is `server/`). The default `../` serves the repo root, so the
# Hono server hosts both API and PWA on the same origin. Leave as-is unless
# you've moved the front-end somewhere else.
STATIC_DIR=../

# CORS allow-list. Leave empty for the default same-origin setup (PWA
# served by this server). Set to your PWA's origin only if you host the
# PWA on a different domain (e.g. GitHub Pages, https://you.github.io).
ALLOWED_ORIGIN=
